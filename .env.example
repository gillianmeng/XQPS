## Feishu / Bitable config (DO NOT commit real secrets)
FEISHU_APP_ID="cli_xxx"
FEISHU_APP_SECRET="xxx"
FEISHU_APP_TOKEN="xxx"          # Bitable app token
FEISHU_TABLE_ID="tblxxx"        # Bitable table id

## Streamlit OAuth redirect (prod should be your public domain)
REDIRECT_URI="http://localhost:8501"

## Runtime mode
APP_ENV="production"
ENABLE_DEMO_LOGIN="false"
ENABLE_DEV_TOOLS="false"

